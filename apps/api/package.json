{
  "name": "@familia/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "test": "vitest run",
    "test:invariants": "vitest run --reporter=verbose tests/invariants",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@familia/audit": "workspace:*",
    "@familia/consent-engine": "workspace:*",
    "@familia/copy": "workspace:*",
    "@familia/crypto": "workspace:*",
    "@familia/domain": "workspace:*",
    "@familia/extraction": "workspace:*",
    "@familia/state-machines": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@prisma/client": "^5.20.0",
    "bullmq": "^5.13.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "opossum": "^8.1.4",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@familia/eslint-config": "workspace:*",
    "@familia/tsconfig": "workspace:*",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "rimraf": "^6.0.1",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/opossum": "^8.1.8",
    "eslint": "^8.57.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
