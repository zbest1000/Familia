# Normalize line endings to LF in the repo.
# Windows checkouts will still see CRLF locally if core.autocrlf=true.
* text=auto eol=lf

# Treat binaries as binaries.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
