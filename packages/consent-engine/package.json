{
  "name": "@familia/consent-engine",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:invariants": "vitest run --reporter=verbose tests/invariants",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@familia/domain": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@familia/eslint-config": "workspace:*",
    "@familia/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "fast-check": "^3.22.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
